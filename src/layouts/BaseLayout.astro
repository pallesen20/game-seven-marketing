---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://gamesevenmarketing.com/og-image.png',
  schema,
  noindex = false,
} = Astro.props;

const canonicalUrl = `https://gamesevenmarketing.com${canonical ?? ''}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#00e87a" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/favicon-black.png" type="image/png" sizes="32x32" />
  <link rel="icon" href="/favicon-black.png" type="image/png" sizes="16x16" />
  <link rel="apple-touch-icon" href="/logo.png" sizes="180x180" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="og:site_name" content="Game Seven Marketing" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:type" content="website" />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />

  <!-- GTM -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-N6B2NTDJ');</script>

  <!-- Schema -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Speculation rules for prefetch/prerender -->
  <script is:inline type="speculationrules">
  {
    "prefetch": [{"source": "document", "where": {"href_matches": "/*"}}],
    "prerender": [{"source": "document", "where": {"href_matches": "/*"}}]
  }
  </script>

  <link rel="stylesheet" href="/base.css" />
</head>
<body>
  <!-- GTM noscript -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N6B2NTDJ"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <Header />
  <slot />
  <Footer />

  <script src="/js/main.js" defer></script>
</body>
</html>
